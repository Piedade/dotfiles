### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term alacritty
set $menu fuzzel
set $config_dir ~/.config/sway

# For multiple monitors:
# output HDMI-A-1 resolution 1920x1080 position 1920,0

## Idle configuration
exec swayidle -w \
   timeout 900 'swaymsg "output * dpms off"' \
        resume 'swaymsg "output * dpms on"'

### Input configuration
input type:touchpad {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
}

input type:keyboard {
    xkb_layout "pt"
    xkb_numlock enabled
    repeat_delay 300
    repeat_rate 50
}

### Appearance
font pango:Lilex Nerd Font Mono 8

# Colors
include $config_dir/theme/colors.conf

# class                 border   backgr  text    indicator child_border
client.focused          $barbie  $cyan   $fg     $blue     $barbie
client.focused_inactive $gray    $bg     $fg     $bg       $gray
client.unfocused        $gray    $bg     $fg     $bg       $gray
client.urgent           $blue    $blue   $bg     $blue     $blue

# Borders & gaps
default_border pixel 2
default_floating_border pixel 2
titlebar_padding 8 4
gaps inner 0
gaps outer 0


### Includes
include $config_dir/workspaces.conf
include $config_dir/rules.conf
include $config_dir/keybindings.conf

### Autostart
exec_always $config_dir/scripts/autostart.sh

exec $config_dir/scripts/launch-apps.sh

