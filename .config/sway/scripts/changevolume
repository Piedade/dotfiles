#!/bin/bash

function is_muted() {
    wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED
}

function get_volume() {
    wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{printf "%d", $2*100}'
}

function get_icon() {
    if is_muted; then
        echo "audio-volume-muted"
    elif [ "$1" -le 30 ]; then
        echo "audio-volume-low"
    elif [ "$1" -le 70 ]; then
        echo "audio-volume-medium"
    else
        echo "audio-volume-high"
    fi
}

function make_bar() {
    local vol=$1
    local filled=$((vol * 2 / 5))
    local empty=$((40 - filled))
    local bar=""
    for ((i = 0; i < filled; i++)); do bar+="█"; done
    for ((i = 0; i < empty; i++)); do bar+="░"; done
    echo "$bar"
}

function send_notification() {
    local volume=$(get_volume)
    local icon=$(get_icon "$volume")
    local bar=$(make_bar "$volume")
    notify-send -a "changevolume" -u low \
        -h string:x-canonical-private-synchronous:volume \
        -h int:value:"$volume" \
        -i "$icon" \
        "Volume ${volume}%" \
        "$bar" \
        -t 2000
}

function is_mic_muted() {
    wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -q MUTED
}

case $1 in
up)
    wpctl set-volume --limit 1.0 @DEFAULT_AUDIO_SINK@ 5%+
    pkill -SIGRTMIN+2 waybar
    send_notification
    ;;
down)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    pkill -SIGRTMIN+2 waybar
    send_notification
    ;;
mute)
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    pkill -SIGRTMIN+2 waybar
    if is_muted; then
        notify-send -a "changevolume" -u low \
            -h string:x-canonical-private-synchronous:volume \
            -h int:value:0 \
            -i "audio-volume-muted" \
            "Volume Muted" \
            "░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░" \
            -t 2000
    else
        send_notification
    fi
    ;;
micmute)
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
    if is_mic_muted; then
        notify-send -a "changevolume" -u low \
            -h string:x-canonical-private-synchronous:volume \
            -i "microphone-sensitivity-muted" \
            "Microphone Muted" \
            -t 2000
    else
        notify-send -a "changevolume" -u low \
            -h string:x-canonical-private-synchronous:volume \
            -i "microphone-sensitivity-high" \
            "Microphone Active" \
            -t 2000
    fi
    ;;
esac
