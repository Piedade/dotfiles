#!/bin/bash
TIMEOUT=30

wait_for_networks() {
    local msg="${1:-A inicializar WiFi...}"
    local elapsed=0

    echo "$msg" | fuzzel --dmenu --prompt "WiFi: " --no-exit-on-keyboard-focus-loss --lines 1 &
    local loading=$!

    until nmcli -t -f SSID device wifi list --rescan no 2>/dev/null | grep -qE "^.+$"; do
        sleep 1
        elapsed=$((elapsed + 1))
        if [ "$elapsed" -ge "$TIMEOUT" ]; then
            kill "$loading" 2>/dev/null
            notify-send "WiFi" "Sem redes encontradas (wifi está ligado?)"
            exit 1
        fi
    done

    kill "$loading" 2>/dev/null
    wait "$loading" 2>/dev/null
}

if [ "$(nmcli radio wifi)" = "disabled" ]; then
    nmcli radio wifi on &
fi

wait_for_networks "A inicializar WiFi..."

build_list() {
    local rescan="${1:-no}"
    nmcli -t -f SSID,SIGNAL,SECURITY,FREQ device wifi list --rescan "$rescan" \
        | while IFS=: read -r ssid signal security freq; do
            [ -z "$ssid" ] && continue
            sig=$((signal + 0))
            if   [ "$sig" -ge 75 ]; then icon="󰤨"
            elif [ "$sig" -ge 50 ]; then icon="󰤥"
            elif [ "$sig" -ge 25 ]; then icon="󰤢"
            else icon="󰤟"; fi
            [ -z "$security" ] || [ "$security" = "--" ] && lock="  " || lock="󰌾 "
            freq_mhz=$(echo "$freq" | grep -oE '[0-9]+' | head -1)
            [ "$freq_mhz" -ge 5000 ] 2>/dev/null && band="5G " || band="2.4G"
            printf "%s %s  %-14s %3d%%  %s\n" "$icon" "$lock" "$ssid" "$sig" "$band"
        done
}

RESCAN="󰑐  Rescan"
DISCONNECT="󰤮  Desligar"
NETWORK_LIST=$(build_list)

while true; do
    SELECTION=$(printf "%s\n%s\n%s" "$NETWORK_LIST" "$RESCAN" "$DISCONNECT" \
        | fuzzel --dmenu --prompt "WiFi: " --width=30 --no-exit-on-keyboard-focus-loss)

    [ -z "$SELECTION" ] && exit 0

    if [ "$SELECTION" = "$DISCONNECT" ]; then
        nmcli radio wifi off
        notify-send "WiFi" "Desligado"
        exit 0
    fi

    if [ "$SELECTION" = "$RESCAN" ]; then
        echo "A procurar redes..." | fuzzel --dmenu --prompt "WiFi: " --lines 1 &
        LOADING=$!
        NETWORK_LIST=$(build_list yes)
        kill "$LOADING" 2>/dev/null
        wait "$LOADING" 2>/dev/null
        continue
    fi

    break
done

SSID=$(echo "$SELECTION" | sed -E 's/^. .{1,2}  //' | sed -E 's/ +[0-9]+%$//' | sed 's/ *$//')
[ -z "$SSID" ] && exit 0

if nmcli connection show "$SSID" &>/dev/null; then
    nmcli connection up "$SSID"
    notify-send "WiFi" "Ligado a $SSID"
    exit 0
fi

PASS=$(echo "" | fuzzel --dmenu --prompt "Password: " --password)
[ -z "$PASS" ] && exit 0

nmcli device wifi connect "$SSID" password "$PASS"
notify-send "WiFi" "Ligado a $SSID"
