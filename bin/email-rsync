#!/bin/bash

USER_CPANEL="$1"
DOMINIO="$2"
CONTA_EMAIL="$3"

if [ $# -eq 0 ]; then
    read -rp "User cPanel: " USER_CPANEL
    if [ -z "$USER_CPANEL" ]; then echo "Erro: user cPanel é obrigatório."; exit 1; fi

    read -rp "Domínio: " DOMINIO
    if [ -z "$DOMINIO" ]; then echo "Erro: domínio é obrigatório."; exit 1; fi

    read -rp "Conta de email: " CONTA_EMAIL
    if [ -z "$CONTA_EMAIL" ]; then echo "Erro: conta de email é obrigatória."; exit 1; fi
else
    if [ -z "$USER_CPANEL" ] || [ -z "$DOMINIO" ] || [ -z "$CONTA_EMAIL" ]; then
        echo "Uso: $0 <user_cpanel> <dominio> <conta_email>"
        exit 1
    fi
fi

EMAIL_COMPLETO="$CONTA_EMAIL@$DOMINIO"
BASE_DIR="$HOME/Downloads/.email-rsync"
CAMINHO_LOCAL_CONTA="$BASE_DIR/$DOMINIO/$CONTA_EMAIL"
LOG_DIR="$BASE_DIR/$DOMINIO/log"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/rsync_${CONTA_EMAIL}.log"

if [ ! -d "$CAMINHO_LOCAL_CONTA" ]; then
    msg="❌ [$(date '+%Y-%m-%d %H:%M:%S')] Pasta de origem não encontrada: $CAMINHO_LOCAL_CONTA"
    echo "$msg" | tee -a "$LOG_FILE"
    echo "   Cria-a e coloca os emails do Maildir dentro:" | tee -a "$LOG_FILE"
    echo "   mkdir -p $CAMINHO_LOCAL_CONTA" | tee -a "$LOG_FILE"
    exit 1
fi

echo ""
echo "  Conta:      $EMAIL_COMPLETO"
echo "  Origem:     $CAMINHO_LOCAL_CONTA/"
echo "  Destino:    $USER_CPANEL@server:/home/$USER_CPANEL/mail/$DOMINIO/$CONTA_EMAIL/"
echo "  Log:        $LOG_FILE"
echo ""

read -rp "Continuar? [y/N]: " answer
case "$answer" in
    [Yy]*) ;;
    *) echo "Cancelado."; exit 0 ;;
esac

# GNOME Keyring SSH agent (necessário para ssh key com passphrase)
export SSH_AUTH_SOCK="/run/user/$(id -u)/keyring/ssh"

DATA_ATUAL=$(date "+%Y-%m-%d %H:%M:%S")
echo "=== [$DATA_ATUAL] SYNCING: $EMAIL_COMPLETO ===" | tee -a "$LOG_FILE"

rsync -avz --exclude="dovecot*" --exclude="maildirsize" --exclude="tmp/" \
    "$CAMINHO_LOCAL_CONTA/" \
    "$USER_CPANEL@server:/home/$USER_CPANEL/mail/$DOMINIO/$CONTA_EMAIL/" 2>&1 | tee -a "$LOG_FILE"
STATUS=${PIPESTATUS[0]}

DATA_FIM=$(date "+%Y-%m-%d %H:%M:%S")
if [ $STATUS -eq 0 ]; then
    msg="=== [$DATA_FIM] TERMINADA COM SUCESSO: $EMAIL_COMPLETO ==="
else
    msg="❌ [$DATA_FIM] ERRO: Falha no rsync para a conta $EMAIL_COMPLETO"
fi
echo "$msg" | tee -a "$LOG_FILE"

echo "------------------------------------------------------------------" | tee -a "$LOG_FILE"
